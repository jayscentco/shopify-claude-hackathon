# === YOUR TEAM CREDENTIALS (from your printed card) ===
# Token starts with shpss_ — copy the full string
SHOPIFY_ACCESS_TOKEN=shpss_your_token_here
# Just the domain, no https:// prefix
SHOPIFY_STORE_URL=gzh-XX.myshopify.com

# === ORDER SIMULATOR ===
# Creates fake orders to keep data flowing. Only ONE team member should have this enabled.
SIMULATOR_ENABLED=true
# Seconds between simulated orders
SIMULATOR_INTERVAL_MIN=60
SIMULATOR_INTERVAL_MAX=180
